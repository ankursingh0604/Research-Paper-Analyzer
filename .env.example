# OpenAI API key - https://platform.openai.com/apikey
OPENAI_API_KEY=your_openai_api_key_here

# Model to use for all agents 
OPENAI_MODEL=gpt-4o-mini

# Review quality threshold (0-10). Below this, an agent's output is regenerated.
QUALITY_THRESHOLD=7

# Max regeneration attempts per agent before force-accepting the best attempt
MAX_RETRIES=2
